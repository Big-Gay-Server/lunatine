views:
  - type: table
    name: Table
    filters:
      and:
        - file.path.contains("SPECIES")
        - file.ext != "base"
        - '!aliases.contains("Species")'
    order:
      - title
      - Average Lifespan
      - Descended Species
      - Parent Species
    sort:
      - property: file.name
        direction: DESC
    columnSize:
      note.Average Lifespan: 145
