formulas:
  type: (file.folder).split("/").slice(1)
views:
  - type: table
    name: Table
    filters:
      and:
        - file.ext == "md"
        - file.folder.contains("STORY/")
    order:
      - file.name
      - formula.type
      - Status
      - order
      - Author
      - Characters
    sort:
      - property: Author
        direction: DESC
      - property: order
        direction: ASC
    columnSize:
      formula.type: 146
      note.order: 49
      note.Status: 96
